{
  "name": "@dermaos/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "lint": "eslint src --ext .ts",
    "patient-phi:encrypt-legacy": "tsx src/scripts/encrypt-legacy-patient-phi.ts",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:rollback": "tsx src/db/migrate.ts rollback",
    "smoke:rls": "tsx src/__tests__/rls-isolation.smoke.ts",
    "backfill:name-tokens":     "tsx src/scripts/rebuild-name-tokens.ts",
    "backfill:channels-config": "tsx src/scripts/encrypt-channels-config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "@dermaos/shared": "workspace:*",
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.28.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "mammoth": "^1.8.0",
    "@google-cloud/storage": "^7.14.0",
    "opossum": "^8.1.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.0",
    "typesense": "^1.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/opossum": "^8.1.9",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
