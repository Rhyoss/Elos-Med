{
  "name": "@dermaos/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:rollback": "tsx src/db/migrate.ts rollback"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "@trpc/server": "^11.0.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.28.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/cookie": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "ioredis": "^5.4.0",
    "minio": "^8.0.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "typesense": "^1.8.0",
    "zod": "^3.24.0",
    "@dermaos/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
