# ─────────────────────────────────────────────────────────────────────────────
# DermaOS Development Environment — Quick Start
# Copy this to .env.local and customize for your machine
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=dermaos_dev
POSTGRES_USER=dermaos_dev
POSTGRES_PASSWORD=dev_password_only_local_insecure
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=dev_redis_password_local_only
REDIS_PORT=6379

# ─── MinIO (Object Storage) ──────────────────────────────────────────────────
MINIO_ROOT_USER=dev_minio
MINIO_ROOT_PASSWORD=dev_minio_password_local_only
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_URL=http://localhost:9001

# ─── Typesense ───────────────────────────────────────────────────────────────
TYPESENSE_API_KEY=dev_typesense_key_local_only_12345678901234567890
TYPESENSE_PORT=8108

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_DEFAULT_MODEL=llama3.1:7b

# ─── JWT (NEVER use these in production) ──────────────────────────────────────
JWT_SECRET=dev_jwt_secret_do_not_use_in_production_replace_immediately_12345
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_different_from_above_never_prod_use_1234
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Criptografia (AES-256 — dev dummy key) ─────────────────────────────────
# FOR DEVELOPMENT ONLY: 0011223344556677889900112233445588990011223344556677889900112233
ENCRYPTION_KEY=0011223344556677889900112233445588990011223344556677889900112233

# ─── Claude API (leave blank for local development) ─────────────────────────
CLAUDE_API_KEY=

# ─── AI Service ──────────────────────────────────────────────────────────────
AI_SERVICE_KEY=dev_ai_service_key_local_only
AI_PORT=8000

# ─── SMTP / Email (Mailhog for local dev) ───────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM="DermaOS Local <noreply@dermaos.local>"

# ─── Frontend ────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_STORAGE_URL=http://localhost:9000
NEXT_PUBLIC_APP_NAME=DermaOS Dev
NEXT_PUBLIC_APP_VERSION=1.0.0-dev

# ─── API Backend ─────────────────────────────────────────────────────────────
API_PORT=3001
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# ─── pgAdmin (development only) ──────────────────────────────────────────────
PGADMIN_EMAIL=admin@dermaos.local
PGADMIN_PASSWORD=dev_pgadmin_local_only
PGADMIN_PORT=5050

# ─── WhatsApp / Omnichannel (stub for dev) ──────────────────────────────────
WHATSAPP_API_URL=http://localhost:3001
WHATSAPP_API_TOKEN=dev_token
WHATSAPP_PHONE_NUMBER_ID=dev_number
WHATSAPP_VERIFY_TOKEN=dev_verify_token

# ─── Webhooks ────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=dev_webhook_secret_local_only
