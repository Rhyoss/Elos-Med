# =============================================================================
# DermaOS — Environment Variables
# Copie para .env e preencha com valores reais antes de iniciar.
# NUNCA commite o arquivo .env com valores reais.
# =============================================================================

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# A separação ADMIN x APP é OBRIGATÓRIA. SEC-01 (auditoria 2026-04-28):
#   - POSTGRES_ADMIN_USER     → SUPERUSER, usado APENAS no bootstrap/migrations.
#   - POSTGRES_APP_USER       → conta da API/Web/SSR (NOSUPERUSER, NOBYPASSRLS).
#   - POSTGRES_WORKER_USER    → conta dos jobs em background.
#   - POSTGRES_READONLY_USER  → conta de BI/relatórios.
# Em Cloud SQL (GCP), os equivalentes são provisionados via Terraform /
# Cloud Console — POSTGRES_ADMIN_USER vira o usuário com cloudsqlsuperuser e
# os demais são criados pelo script `db/init/000_app_roles.sh` (ou, em
# infra-as-code, por `google_sql_user` com password vindo do Secret Manager).

POSTGRES_DB=dermaos
POSTGRES_PORT=5432

# Bootstrap / migrations (NÃO usar em runtime do app)
POSTGRES_ADMIN_USER=dermaos_admin
POSTGRES_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password_here

# Runtime — API e Web (NOSUPERUSER NOBYPASSRLS)
POSTGRES_APP_USER=dermaos_app
POSTGRES_APP_PASSWORD=CHANGE_ME_strong_app_password_here

# Runtime — Worker / jobs em background
POSTGRES_WORKER_USER=dermaos_worker
POSTGRES_WORKER_PASSWORD=CHANGE_ME_strong_worker_password_here

# Runtime — Read-only / BI
POSTGRES_READONLY_USER=dermaos_readonly
POSTGRES_READONLY_PASSWORD=CHANGE_ME_strong_readonly_password_here

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here
REDIS_PORT=6379

# ─── Google Cloud Storage ────────────────────────────────────────────────────
# Local: fake-gcs-server emula GCS. Em GCP, ADC (Application Default Credentials)
# resolve automaticamente — não precisa de credenciais explícitas.
GCS_EMULATOR_PORT=4443
# GCS_PROJECT_ID: opcional em GCP (inferido da ADC); "local" para emulador.
# GCS_BUCKET_PREFIX: vazio para dev local, "staging-elosmed" ou "prod-elosmed" em GCP.

# ─── Typesense ───────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
TYPESENSE_API_KEY=CHANGE_ME_typesense_api_key_here
TYPESENSE_PORT=8108

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
# Modelo padrão para análise clínica (dados PHI ficam locais)
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# ─── JWT (NUNCA usar os valores de exemplo em produção) ──────────────────────
# SEC-06: cada segredo DEVE ser distinto. Gere 3 valores independentes com:
#   openssl rand -base64 64
JWT_SECRET=CHANGE_ME_jwt_access_secret_minimum_64_chars_random
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_minimum_64_chars_random_DIFFERENT
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# SEC-07: cookie HMAC distinto dos JWT secrets
#   openssl rand -base64 64
COOKIE_SECRET=CHANGE_ME_cookie_signing_secret_minimum_64_chars_random_DIFFERENT

# SEC-08: lista CSV de origins permitidos em produção. Em dev, vazio.
# Ex.: "https://app.dermaos.com.br,https://portal.dermaos.com.br"
CORS_ORIGINS=

# ─── Criptografia (AES-256 para dados PHI) ───────────────────────────────────
# Gere com: openssl rand -hex 32  (deve ter EXATAMENTE 64 chars hex = 32 bytes)
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_for_aes256_encryption_key_replace_this

# SEC-13: chave HMAC para blind-index de buscas em campos cifrados
#   openssl rand -hex 32   (separada da ENCRYPTION_KEY)
SEARCH_INDEX_KEY=CHANGE_ME_64_hex_chars_search_index_key_DIFFERENT_from_encryption

# SEC-21: URL pública do app (usada em links de email — reset, invite)
APP_URL=http://localhost:3000

# ─── Claude API (IA cloud — apenas dados não-PHI) ────────────────────────────
CLAUDE_API_KEY=sk-ant-CHANGE_ME

# ─── AI Service ──────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
AI_SERVICE_KEY=CHANGE_ME_ai_service_internal_key_here
AI_PORT=8000

# ─── SMTP / Email ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@dermaos.com.br
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM="DermaOS <noreply@dermaos.com.br>"

# ─── Frontend ────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
NEXT_PUBLIC_STORAGE_URL=http://localhost/storage
NEXT_PUBLIC_APP_NAME=DermaOS
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─── API Backend ─────────────────────────────────────────────────────────────
API_PORT=3001
# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── pgAdmin (apenas dev) ────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@dermaos.dev
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password
PGADMIN_PORT=5050

# ─── WhatsApp / Omnichannel ──────────────────────────────────────────────────
# WhatsApp Business API (via provider: Twilio, Z-API, etc.)
WHATSAPP_API_URL=https://api.whatsapp-provider.com
WHATSAPP_API_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_webhook_verify_token

# ─── Webhooks ────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=CHANGE_ME_webhook_hmac_secret
